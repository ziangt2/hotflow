# OpenAI content generation
OPENAI_API_KEY=
HOTFLOW_OPENAI_MODEL=gpt-5.4-mini

# Option 1: your own remote JSON trends endpoint
HOTFLOW_REMOTE_JSON_URL=
HOTFLOW_REMOTE_JSON_HEADERS={"Authorization":"Bearer your-token"}

